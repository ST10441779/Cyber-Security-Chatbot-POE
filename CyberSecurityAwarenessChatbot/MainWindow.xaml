<Window x:Class="CyberSecurityAwarenessChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Chatbot"
        Height="750"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

    </Window.Resources>

    <Grid Margin="10">

        <TabControl FontSize="14">

            <!-- ================================= -->
            <!-- CHATBOT TAB -->
            <!-- ================================= -->

            <TabItem Header="💬 Chatbot">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox x:Name="txtChat"
                             Grid.Row="0"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Background="Black"
                             Foreground="Lime"
                             FontFamily="Consolas"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal">

                        <TextBox x:Name="txtUserInput"
                                 Width="750"
                                 Height="35"/>

                        <Button Content="Send"
                                Width="120"
                                Height="35"
                                Click="BtnSend_Click"/>

                    </StackPanel>

                </Grid>

            </TabItem>

            <!-- ================================= -->
            <!-- TASK ASSISTANT TAB -->
            <!-- ================================= -->

            <TabItem Header="📋 Task Assistant">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="txtTaskTitle"
                             Grid.Row="0"
                             Height="35"
                             ToolTip="Task Title"/>

                    <TextBox x:Name="txtTaskDescription"
                             Grid.Row="1"
                             Height="35"
                             ToolTip="Task Description"/>

                    <DatePicker x:Name="dpReminder"
                                Grid.Row="2"
                                Margin="5"/>

                    <ListBox x:Name="lstTasks"
                             Grid.Row="3"
                             Margin="5"/>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button Content="Add Task"
                                Width="120"
                                Click="BtnAddTask_Click"/>

                        <Button Content="Complete Task"
                                Width="120"
                                Click="BtnComplete_Click"/>

                        <Button Content="Delete Task"
                                Width="120"
                                Click="BtnDelete_Click"/>

                    </StackPanel>

                </Grid>

            </TabItem>

            <!-- ================================= -->
            <!-- QUIZ TAB -->
            <!-- ================================= -->

            <TabItem Header="🎮 Cyber Quiz">

                <Grid Margin="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="txtQuestion"
                               Grid.Row="0"
                               FontSize="22"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="10"/>

                    <Button x:Name="btnOption1"
                            Grid.Row="1"
                            Height="45"
                            Click="Answer_Click"/>

                    <Button x:Name="btnOption2"
                            Grid.Row="2"
                            Height="45"
                            Click="Answer_Click"/>

                    <Button x:Name="btnOption3"
                            Grid.Row="3"
                            Height="45"
                            Click="Answer_Click"/>

                    <Button x:Name="btnOption4"
                            Grid.Row="4"
                            Height="45"
                            Click="Answer_Click"/>

                    <TextBlock x:Name="txtQuizScore"
                               Grid.Row="5"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="10"/>

                </Grid>

            </TabItem>

            <!-- ================================= -->
            <!-- ACTIVITY LOG TAB -->
            <!-- ================================= -->

            <TabItem Header="📝 Activity Log">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="lstActivity"
                             Grid.Row="0"/>

                    <Button Grid.Row="1"
                            Content="Refresh Log"
                            Width="150"
                            HorizontalAlignment="Center"
                            Click="BtnRefreshLog_Click"/>

                </Grid>

            </TabItem>

        </TabControl>

    </Grid>

</Window>